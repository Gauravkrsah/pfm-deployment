flowchart TD
    Start((Start)) --> Login{Authenticated?}
    Login -->|No| AuthPage[Login Page]
    AuthPage --> Login
    Login -->|Yes| Dashboard[View Dashboard]
    Dashboard --> Action{User Action}
    
    Action -->|Add Expense| Input[Input Text/Form]
